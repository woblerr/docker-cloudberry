# Cloudberry
# -------------------------------------
IMAGE_NAME="cloudberry"
# For Cloudberry on Ubuntu 22.04
TAG=2.1.0-incubating-rc2-ubuntu22.04
# For Cloudberry on Rocky Linux 9
#TAG=2.1.0-incubating-rc2-rockylinux9

# Cloudberry RESTORE
# -------------------------------------
# For Cloudberry on Ubuntu 22.04
RESTORE_TAG=2.1.0-incubating-rc2-ubuntu22.04
# For Cloudberry on Rocky Linux 9
#RESTORE_TAG=2.1.0-incubating-rc2-rockylinux9

EXPOSE_MASTER_PORT=5432
# RESTORE EXPOSE PORTS
EXPOSE_RESTORE_MASTER_PORT=6432

# S3 MinIO
# -------------------------------------
IMAGE_TAG_MINIO=RELEASE.2025-04-22T22-12-26Z
IMAGE_TAG_MINIO_MC=RELEASE.2025-04-16T18-13-26Z
IMAGE_TAG_NGINX=1.27.5-alpine
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minioBackup
MINIO_SITE_REGION=us-west-1
MINIO_DOMAIN=minio.local
S3_MINIO_BUCKET=backup
S3_MINIO_HOSTNAME=myminio
S3_MINIO_KEY=demo
S3_MINIO_KEY_SECRET=demoBackup
